# eBay Browse API credentials
# Copy this file to .env (gitignored) and fill in the real values.
#
# Environment: "sandbox" or "production". Sandbox returns test data only;
# real prospect-card prices require production credentials.
EBAY_ENV=production

# Application credentials from the eBay Developer Program.
# Production App ID looks like:   AriSpies-keys-PRD-xxxxxxxxx
# Sandbox    App ID looks like:   AriSpies-keys-SBX-xxxxxxxxx
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Option A: paste a short-lived User access token directly (expires ~2hrs).
EBAY_BEARER_TOKEN=

# Option B: paste a User refresh token for auto-refresh of access tokens.
# Long-lived (~18 months). Best for unattended runs.
EBAY_USER_REFRESH_TOKEN=
